# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1
#CSRF_TRUSTED_ORIGINS=https://your-public-hostname.example.com
# Set true when serving over HTTPS (Cloudflare tunnel); false for local HTTP testing
SECURE_COOKIES=false

# Database (defaults to SQLite at BASE_DIR/db.sqlite3; set these for Postgres)
#DB_ENGINE=postgresql
#DB_NAME=ops_event_tools
#DB_HOST=localhost
#DB_USER=ops
#DB_PASSWORD=secret

# Google Sheets service account (path to JSON key file)
GOOGLE_CREDENTIALS_FILE=credentials.json

# Gmail SMTP for emailed sign-in codes (account needs 2FA + an app password).
# Store the app password WITHOUT spaces. Unset = codes print to server logs.
#EMAIL_HOST_USER=youraccount@gmail.com
#EMAIL_HOST_PASSWORD=abcdefghijklmnop
#DEFAULT_FROM_EMAIL=youraccount@gmail.com

# Google OAuth sign-in. Create an OAuth client (Web application) in Google
# Cloud Console with authorized redirect URIs:
#   https://sc.edolas.org/accounts/google/login/callback/
#   http://localhost:3001/accounts/google/login/callback/
# Behind the tunnel, SECURE_COOKIES=true is required or the redirect_uri is
# generated as http:// and Google rejects it.
#GOOGLE_OAUTH_CLIENT_ID=xxx.apps.googleusercontent.com
#GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-...

# In-app backups (SQLite snapshot + media archive, written by the web process)
BACKUP_ENABLED=true
#BACKUP_DIR=/opt/ops-event-tools/backups
BACKUP_INTERVAL_HOURS=24
BACKUP_KEEP=14

# HTTPS certificates issued in-app (ACME); path only
#CERT_DIR=/opt/ops-event-tools/certs
